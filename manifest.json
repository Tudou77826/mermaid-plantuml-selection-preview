{
  "manifest_version": 3,
  "name": "Mermaid & PlantUML 选区预览",
  "version": "0.6.0",
  "description": "选中 Mermaid 或 PlantUML 源码后，通过右键菜单在当前页面浮层中安全预览。",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'"
  },
  "action": {
    "default_title": "选中 Mermaid 或 PlantUML 源码后点击右键预览"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
