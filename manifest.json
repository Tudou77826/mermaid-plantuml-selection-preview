{
  "manifest_version": 3,
  "name": "Mermaid & PlantUML 选区预览",
  "version": "0.7.0",
  "description": "选中或粘贴 Mermaid、PlantUML 源码，在当前页面浮层中安全预览。",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'"
  },
  "action": {
    "default_title": "预览当前选区中的 Mermaid / PlantUML",
    "default_popup": "action.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
